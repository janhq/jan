{
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Atomic Chat",
        "width": 1200,
        "minWidth": 1024,
        "height": 800,
        "minHeight": 740,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": true,
        "center": true,
        "hiddenTitle": true,
        "transparent": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "windowEffects": {
          "effects": ["fullScreenUI", "mica", "tabbed", "blur", "acrylic"],
          "state": "active"
        },
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "targets": ["nsis", "msi"],
    "resources": ["resources/pre-install/**/*", "resources/LICENSE", "resources/bin/jan-cli.exe", "resources/llamacpp-backend/**/*"],
    "externalBin": ["resources/bin/bun", "resources/bin/uv"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      },
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      }
    }
  }
}
